{
  "name": "@badjoke-lab/yukue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:matsuri:pages": "pnpm --filter @badjoke-lab/yukue-matsuri... build",
    "build:matsuri:workers": "node scripts/build-matsuri-workers.mjs",
    "check:yukue:deployment-topology": "node scripts/check-yukue-deployment-topology.mjs",
    "audit:yukue:future-site-seeds": "node scripts/build-yukue-future-site-seed-inventory.mjs && node scripts/build-yukue-future-site-seed-provenance-bundle.mjs && node scripts/check-yukue-future-site-seed-artifact-contract.mjs",
    "check:yukue:future-site-seed-artifact-contract": "node scripts/check-yukue-future-site-seed-artifact-contract.mjs",
    "audit:yukue:future-site-seed-readiness": "node scripts/audit-yukue-future-site-seed-readiness.mjs",
    "check:matsuri:pages": "node scripts/check-matsuri-pages-build.mjs",
    "check:matsuri:workers-config": "node scripts/check-matsuri-workers-config.mjs",
    "check:matsuri:consistency": "node scripts/check-matsuri-consistency.mjs",
    "check:matsuri:canonical-metadata": "node scripts/check-matsuri-canonical-metadata.mjs",
    "check:matsuri:semantics": "pnpm --filter @badjoke-lab/yukue-validation build && node scripts/check-matsuri-semantics.mjs",
    "check:matsuri:evidence": "node scripts/check-matsuri-evidence.mjs",
    "check:matsuri:content": "node scripts/check-matsuri-public-content.mjs",
    "check:matsuri:browser": "playwright test --config=playwright.config.mjs",
    "check:matsuri:canonical-search": "playwright test --config=playwright.canonical-search.config.mjs",
    "check:matsuri:crawler-reachability": "node scripts/check-matsuri-crawler-reachability.mjs",
    "check:matsuri:indexability-preflight": "node scripts/check-matsuri-indexability-preflight.mjs",
    "check:matsuri:search-engine-submission-record": "node scripts/check-matsuri-search-engine-submission-record.mjs",
    "check:matsuri:analytics-activation-record": "node scripts/check-matsuri-analytics-activation-record.mjs",
    "check:matsuri:deployed": "node scripts/check-matsuri-deployed.mjs",
    "check:matsuri:canonical": "node scripts/check-matsuri-deployed.mjs --canonical",
    "capture:matsuri:screenshots": "node scripts/capture-matsuri-screenshots.mjs",
    "audit:matsuri:screenshots": "node scripts/audit-matsuri-screenshots.mjs",
    "audit:matsuri:freshness": "node scripts/audit-matsuri-data-freshness.mjs",
    "audit:matsuri:relations": "node scripts/audit-matsuri-relation-coverage.mjs",
    "contact:matsuri:screenshots": "node scripts/build-matsuri-contact-sheets.mjs",
    "verify:matsuri:pages": "pnpm build:matsuri:pages && pnpm check:matsuri:pages && pnpm check:matsuri:canonical-metadata && pnpm check:matsuri:consistency && pnpm check:matsuri:semantics && pnpm check:matsuri:evidence && pnpm check:matsuri:content && pnpm check:matsuri:browser",
    "verify:matsuri:workers": "node scripts/verify-matsuri-workers.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "freeze:matsuri:release": "node scripts/freeze-matsuri-release-candidate.mjs",
    "gate:matsuri:repository": "pnpm verify:matsuri:workers && pnpm verify:release && pnpm check:matsuri:search-engine-submission-record && pnpm check:matsuri:analytics-activation-record && pnpm freeze:matsuri:release && node scripts/check-matsuri-readiness-gate.mjs",
    "check": "pnpm -r --if-present check",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@axe-core/playwright": "latest",
    "@playwright/test": "latest",
    "typescript": "6.0.3"
  }
}
