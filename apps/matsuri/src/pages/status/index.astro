---
import MatsuriReferenceShell from "../../components/MatsuriReferenceShell.astro";
import { matsuriProjection } from "../../data/matsuri-projection.js";

const counts = {
  entities: matsuriProjection.json.entities.length,
  currentStates: matsuriProjection.json.current_states.length,
  occurrences: matsuriProjection.json.occurrences.length,
  changeEvents: matsuriProjection.json.change_events.length,
  relations: matsuriProjection.json.relations.length,
};
---

<MatsuriReferenceShell
  title="ステータス｜祭のゆくえ"
  description="祭のゆくえの公開データ、検索、machine-readable layer、更新方針の現在状況を示します。"
  kicker="Status"
  heading="公開ステータス"
  intro="公開中の記録量と、リポジトリ内で確認済みの公開基盤を示します。件数はbuild時の承認済みPublic Projectionから生成されます。"
  activeReference="status"
>
  <section>
    <h2>現在の公開レコード</h2>
    <dl class="status-counts">
      <div><dt>Entities</dt><dd data-record-count="entities">{counts.entities}</dd></div>
      <div><dt>Current States</dt><dd data-record-count="current_states">{counts.currentStates}</dd></div>
      <div><dt>Occurrences</dt><dd data-record-count="occurrences">{counts.occurrences}</dd></div>
      <div><dt>Change Events</dt><dd data-record-count="events">{counts.changeEvents}</dd></div>
      <div><dt>Relations</dt><dd data-record-count="relations">{counts.relations}</dd></div>
    </dl>
  </section>

  <section>
    <h2>公開基盤</h2>
    <dl class="status-list">
      <div data-infrastructure-status="public-projection-ready"><dt>Public Projection</dt><dd>承認済みrecordのみを公開</dd></div>
      <div data-infrastructure-status="browse-ready"><dt>Browse</dt><dd>祭礼・民俗芸能・地域・変化・組織・状態</dd></div>
      <div data-infrastructure-status="search-artifact-ready"><dt>Search</dt><dd>Pagefind静的indexをbuild時に生成し、リポジトリ検証済み</dd></div>
      <div data-infrastructure-status="machine-readable-ready"><dt>Machine-readable layer</dt><dd>JSON feeds、manifest、discovery filesを生成し、相互整合性を検査</dd></div>
      <div data-infrastructure-status="deployment-artifact-ready"><dt>Deployment artifact</dt><dd>CIで必須HTML、検索runtime、公開データファイル、内部リンク、ブラウザ表示を検査</dd></div>
      <div data-infrastructure-status="public-deployment-verified"><dt>Public deployment</dt><dd>Cloudflare Workers Static Assetsで公開中。canonical origin、HTTPS、Search、crawler reachability、sitemapを検証済み</dd></div>
      <div data-infrastructure-status="analytics-owner-access-pending"><dt>Web Analytics</dt><dd>所有者による有効化待ち。Automatic setup有効化後に別工程でproduction trafficを確認</dd></div>
    </dl>
  </section>

  <section>
    <h2>更新の考え方</h2>
    <p>記録は、確認日と根拠資料に基づく観測値です。後続の確認で新しいOccurrence、Change Event、Relation、State Snapshotが追加される場合があります。</p>
    <p>件数の増加そのものを目的にせず、現在状態、履歴、関係、Evidenceの偏りを避けることを優先します。</p>
  </section>

  <section>
    <h2>関連情報</h2>
    <p><a href="/methodology/">方法論</a>で記録判断の原則を、<a href="/data/">データ利用案内</a>で公開JSONとdiscovery filesを確認できます。</p>
  </section>
</MatsuriReferenceShell>

<style>
  .status-counts,
  .status-list {
    margin: 0;
    border-top: var(--rule-strong);
  }

  .status-counts div,
  .status-list div {
    display: grid;
    grid-template-columns: minmax(10rem, 1fr) minmax(0, 2fr);
    gap: var(--space-6);
    padding-block: var(--space-4);
    border-bottom: var(--rule-standard);
  }

  dt {
    color: var(--color-text);
  }

  dd {
    margin: 0;
  }

  .status-counts dd {
    color: var(--color-accent);
    font-size: var(--font-size-h3);
  }

  @media (max-width: 640px) {
    .status-counts div,
    .status-list div {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
