---
import ActionLink from "@badjoke-lab/yukue-ui/components/ActionLink.astro";
import ChangeTimeline from "@badjoke-lab/yukue-ui/components/ChangeTimeline.astro";
import DesignationList from "@badjoke-lab/yukue-ui/components/DesignationList.astro";
import EvidenceList from "@badjoke-lab/yukue-ui/components/EvidenceList.astro";
import ImageSet from "@badjoke-lab/yukue-ui/components/ImageSet.astro";
import ObservationSnapshot from "@badjoke-lab/yukue-ui/components/ObservationSnapshot.astro";
import OccurrenceTable from "@badjoke-lab/yukue-ui/components/OccurrenceTable.astro";
import OverviewGrid from "@badjoke-lab/yukue-ui/components/OverviewGrid.astro";
import PageShell from "@badjoke-lab/yukue-ui/components/PageShell.astro";
import PlaceMap from "@badjoke-lab/yukue-ui/components/PlaceMap.astro";
import RelationList from "@badjoke-lab/yukue-ui/components/RelationList.astro";
import SearchForm from "@badjoke-lab/yukue-ui/components/SearchForm.astro";
import Section from "@badjoke-lab/yukue-ui/components/Section.astro";
import SiteFooter from "@badjoke-lab/yukue-ui/components/SiteFooter.astro";
import SiteHeader from "@badjoke-lab/yukue-ui/components/SiteHeader.astro";

const navItems = [
  { label: "祭礼", href: "/festivals/", active: true },
  { label: "民俗芸能", href: "/performances/" },
  { label: "地域", href: "/regions/" },
  { label: "変化", href: "/changes/" },
  { label: "検索", href: "/search/" },
  { label: "このサイトについて", href: "/about/" },
];

const footerGroups = [
  {
    heading: "記録",
    links: [
      { label: "祭礼", href: "/festivals/" },
      { label: "民俗芸能", href: "/performances/" },
    ],
  },
  {
    heading: "調べる",
    links: [
      { label: "地域", href: "/regions/" },
      { label: "変化", href: "/changes/" },
    ],
  },
  {
    heading: "この資料について",
    links: [
      { label: "方法論", href: "/methodology/" },
      { label: "データ", href: "/data/" },
    ],
  },
];

const metrics = [
  { label: "継続中", value: 128, href: "/states/active/" },
  { label: "休止中", value: 7, href: "/states/suspended/" },
  { label: "長期休止", value: 16, href: "/states/dormant/" },
  { label: "復活活動中", value: 5, href: "/states/reviving/" },
  { label: "要確認", value: 11, href: "/states/unknown/" },
];

const overviewItems = [
  { label: "現在状態", value: "継続中", accent: true },
  { label: "確認日", value: "2026年7月10日" },
  { label: "直近の実施", value: "2024年8月4日　開催" },
  { label: "通常開催", value: "閏年の8月第一日曜日" },
  { label: "周期", value: "4年に1度" },
  { label: "地域", value: "埼玉県鶴ヶ島市 脚折地区" },
  { label: "主な場所", value: "白鬚神社、雷電池児童公園" },
  { label: "公式情報", value: "自治体文化財情報", href: "#" },
];

const occurrences = [
  { date: "2024年8月4日", name: "脚折雨乞", region: "埼玉県", outcome: "開催", scale: "通常" },
  { date: "2020年", name: "脚折雨乞", region: "埼玉県", outcome: "未実施", scale: "—" },
  { date: "2016年8月", name: "脚折雨乞", region: "埼玉県", outcome: "開催", scale: "通常" },
];

const changes = [
  { date: "1976年", typeLabel: "復活", summary: "保存活動を経て行事が復活。", resultingState: "継続中", evidenceHref: "#evidence" },
  { date: "1975年", typeLabel: "保存会の結成", summary: "継承組織の形成を確認。", evidenceHref: "#evidence" },
  { date: "1964年", typeLabel: "中断前最後の実施", summary: "この実施を最後に一時中断。", evidenceHref: "#evidence" },
];

const relations = [
  { label: "行われる場所", targetName: "白鬚神社", href: "#places" },
  { label: "儀礼の場所", targetName: "雷電池", href: "#places" },
  { label: "継承組織", targetName: "脚折雨乞行事保存会", href: "#" },
];

const designations = [
  { name: "脚折雨乞", system: "文化財指定", authority: "指定主体の表示例", sourceHref: "#evidence" },
];

const evidence = [
  { targetLabel: "現在状態", sourceTitle: "自治体文化財情報", supportSummary: "継続状況と開催情報の確認用fixture。", sourceHref: "#" },
  { targetLabel: "開催履歴", sourceTitle: "行事概要資料", supportSummary: "実施年と復活履歴の確認用fixture。", sourceHref: "#" },
];

const places = [
  { name: "白鬚神社", address: "埼玉県鶴ヶ島市脚折町6丁目10-20", contextLabel: "出発・祈願地点", mapHref: "#" },
  { name: "雷電池児童公園", address: "埼玉県鶴ヶ島市脚折町5丁目22-1", contextLabel: "雨乞い儀礼地点", mapHref: "#" },
];

const images = [];
---

<PageShell
  site="matsuri"
  title="祭のゆくえ — UI Foundation Preview"
  description="祭礼と民俗芸能の現在、実施履歴、変化、関係、根拠を記録します。"
>
  <SiteHeader
    slot="header"
    siteName="祭のゆくえ"
    romanLabel="Matsuri Yukue"
    navItems={navItems}
  />

  <Section kicker="Foundation Preview" title="祭礼と民俗芸能の記録基盤">
    <div class="yk-prose foundation-intro">
      <p>このページはHome H1本実装ではなく、Stage A共有UI patternの統合確認用です。</p>
    </div>
    <SearchForm
      action="/search/"
      label="祭礼・民俗芸能・地域を検索"
      placeholder="祭礼・民俗芸能・地域を検索"
    />
  </Section>

  <Section kicker="Current Observation" title="現在の観測状況">
    <ObservationSnapshot metrics={metrics} />
  </Section>

  <Section kicker="Integrated Overview" title="概要表示の基準">
    <OverviewGrid items={overviewItems} />
  </Section>

  <Section kicker="Occurrence History" title="開催履歴">
    <OccurrenceTable
      rows={occurrences}
      showName={true}
      showRegion={true}
      showScale={true}
      caption="開催履歴の基盤表示"
    />
  </Section>

  <Section kicker="Change History" title="変化の履歴">
    <ChangeTimeline items={changes} />
  </Section>

  <Section kicker="Connections" title="関係する場所・組織">
    <RelationList items={relations} />
  </Section>

  <Section kicker="Places & Map" title="場所" id="places">
    <PlaceMap
      places={places}
      contextDescription="route-based traditionのため、単一地点ではなく主要地点を分けて表示する基盤例です。"
    />
  </Section>

  <Section kicker="Designations" title="指定">
    <DesignationList items={designations} />
  </Section>

  <Section kicker="Images" title="画像">
    <ImageSet images={images} />
    <p class="foundation-note">approved imageが0件のため、ImageSetは画像UIをrenderしていません。</p>
  </Section>

  <Section kicker="Evidence & Sources" title="根拠と出典" id="evidence">
    <EvidenceList items={evidence} />
    <p class="foundation-action"><ActionLink href="/methodology/" label="検証方法を見る" /></p>
  </Section>

  <SiteFooter
    slot="footer"
    siteName="祭のゆくえ"
    groups={footerGroups}
  />
</PageShell>

<style>
  .foundation-intro {
    margin-bottom: var(--space-8);
  }

  .foundation-action,
  .foundation-note {
    margin: var(--space-6) 0 0;
  }

  .foundation-note {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }
</style>
