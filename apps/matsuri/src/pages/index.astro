---
import ActionLink from "@badjoke-lab/yukue-ui/components/ActionLink.astro";
import Container from "@badjoke-lab/yukue-ui/components/Container.astro";
import ObservationSnapshot from "@badjoke-lab/yukue-ui/components/ObservationSnapshot.astro";
import OccurrenceTable from "@badjoke-lab/yukue-ui/components/OccurrenceTable.astro";
import PageShell from "@badjoke-lab/yukue-ui/components/PageShell.astro";
import SearchForm from "@badjoke-lab/yukue-ui/components/SearchForm.astro";
import Section from "@badjoke-lab/yukue-ui/components/Section.astro";
import SiteFooter from "@badjoke-lab/yukue-ui/components/SiteFooter.astro";
import SiteHeader from "@badjoke-lab/yukue-ui/components/SiteHeader.astro";

const navItems = [
  { label: "祭礼", href: "/festivals/" },
  { label: "民俗芸能", href: "/performances/" },
  { label: "地域", href: "/regions/" },
  { label: "変化", href: "/changes/" },
  { label: "検索", href: "/search/" },
  { label: "このサイトについて", href: "/about/" },
];

const footerGroups = [
  {
    heading: "記録",
    links: [
      { label: "祭礼", href: "/festivals/" },
      { label: "民俗芸能", href: "/performances/" },
      { label: "組織", href: "/organizations/" },
    ],
  },
  {
    heading: "調べる",
    links: [
      { label: "地域", href: "/regions/" },
      { label: "変化", href: "/changes/" },
      { label: "状態", href: "/states/" },
    ],
  },
  {
    heading: "この資料について",
    links: [
      { label: "方法論", href: "/methodology/" },
      { label: "データ", href: "/data/" },
      { label: "ステータス", href: "/status/" },
    ],
  },
];

const fixtureMetrics = [
  { label: "継続中", value: 128, href: "/states/active/" },
  { label: "休止中", value: 7, href: "/states/suspended/" },
  { label: "長期休止", value: 16, href: "/states/dormant/" },
  { label: "復活活動中", value: 5, href: "/states/reviving/" },
  { label: "要確認", value: 11, href: "/states/unknown/" },
];

const fixtureChanges = [
  { date: "2026.06", type: "復活", name: "○○神楽", summary: "長期休止後、奉納を再開。", href: "/changes/example-1/" },
  { date: "2026.05", type: "開催時期変更", name: "△△祭", summary: "通常開催月の変更を確認。", href: "/changes/example-2/" },
  { date: "2026.04", type: "保存会再編", name: "□□踊り", summary: "継承組織の再編を確認。", href: "/changes/example-3/" },
];

const fixtureOccurrences = [
  { date: "2026年8月4日", name: "○○祭", region: "岩手県", outcome: "開催予定" },
  { date: "2026年7月18日", name: "△△神楽", region: "宮崎県", outcome: "開催" },
  { date: "2026年6月12日", name: "□□踊り", region: "秋田県", outcome: "縮小開催" },
];

const exploreItems = [
  { title: "祭礼から", description: "祭・例大祭・神事などの記録をたどる", href: "/festivals/" },
  { title: "民俗芸能から", description: "神楽・獅子舞・踊り・人形芝居などをたどる", href: "/performances/" },
  { title: "地域から", description: "都道府県・市区町村から記録をたどる", href: "/regions/" },
];
---

<PageShell
  site="matsuri"
  title="祭のゆくえ"
  description="祭礼と民俗芸能の現在状態、開催・上演履歴、変化、関係、根拠を記録します。"
>
  <SiteHeader
    slot="header"
    siteName="祭のゆくえ"
    romanLabel="Matsuri Yukue"
    navItems={navItems}
  />

  <section class="home-hero">
    <Container size="wide">
      <p class="home-hero__kicker">祭礼と民俗芸能の記録</p>
      <h1>祭礼と民俗芸能の、<br />現在と変化を記録する。</h1>
      <p class="home-hero__lead">名称、由来、開催時期、場所といった基本情報に加え、現在状態、年ごとの実施履歴、休止・復活・変更、関係する場所と組織、そして根拠資料を記録します。</p>
      <div class="home-hero__search">
        <SearchForm
          action="/search/"
          label="祭礼・民俗芸能・地域を検索"
          placeholder="祭礼・民俗芸能・地域を検索"
        />
      </div>
    </Container>
  </section>

  <Section kicker="Current Observation" title="現在の観測状況" actionHref="/states/" actionLabel="状態から見る">
    <ObservationSnapshot metrics={fixtureMetrics} />
  </Section>

  <Section kicker="Recent Changes" title="最近の変化" actionHref="/changes/" actionLabel="すべての変化を見る">
    <div class="recent-change-list">
      {fixtureChanges.map((change) => (
        <article class="recent-change-row">
          <time>{change.date}</time>
          <span class="recent-change-row__type">{change.type}</span>
          <div>
            <h3><a href={change.href}>{change.name}</a></h3>
            <p>{change.summary}</p>
          </div>
          <ActionLink href={change.href} label="詳細" />
        </article>
      ))}
    </div>
  </Section>

  <Section kicker="Recent Occurrences" title="最近の開催・上演" actionHref="/search/?view=occurrences" actionLabel="開催・上演履歴を見る">
    <OccurrenceTable
      rows={fixtureOccurrences}
      showName={true}
      showRegion={true}
      caption="最近の開催・上演"
    />
  </Section>

  <Section kicker="Explore" title="記録をたどる">
    <div class="explore-grid">
      {exploreItems.map((item) => (
        <a class="explore-item" href={item.href}>
          <strong>{item.title}</strong>
          <span>{item.description}</span>
        </a>
      ))}
    </div>
  </Section>

  <Section kicker="Methodology & Evidence" title="記録の考え方">
    <div class="home-info-grid">
      <article>
        <h3>状態と履歴を分けて記録する</h3>
        <p>現在の状態、一回ごとの開催・上演、長期的な変化を分けて記録します。一度の中止だけで祭礼や芸能そのものを「休止」とは判定しません。</p>
        <ActionLink href="/methodology/" label="検証方法を見る" />
      </article>
      <article>
        <h3>根拠へたどれる記録</h3>
        <p>状態、開催履歴、変化、関係、指定などの重要な記録を、確認に用いた出典と結び付けます。</p>
        <ActionLink href="/methodology/#evidence" label="根拠と出典について" />
      </article>
    </div>
  </Section>

  <Section kicker="Data Access" title="データとして利用する" rule="none">
    <div class="data-access">
      <p>公開ページと同じ承認済みデータから、機械可読な公開データと案内ファイルを生成する方針です。</p>
      <ActionLink href="/data/" label="公開データについて" />
    </div>
  </Section>

  <SiteFooter
    slot="footer"
    siteName="祭のゆくえ"
    groups={footerGroups}
  />
</PageShell>

<style>
  .home-hero {
    padding-block: var(--space-20) var(--space-16);
    border-bottom: var(--rule-standard);
  }

  .home-hero__kicker {
    margin: 0 0 var(--space-4);
    color: var(--color-accent);
    font-size: var(--font-size-sm);
    letter-spacing: 0.12em;
  }

  .home-hero h1 {
    max-width: 13em;
    margin: 0;
    font-size: var(--font-size-hero);
    font-weight: 500;
    letter-spacing: 0.06em;
  }

  .home-hero__lead {
    max-width: var(--container-prose);
    margin: var(--space-6) 0 0;
    color: var(--color-text-soft);
    font-size: var(--font-size-lead);
    line-height: var(--line-height-lead);
  }

  .home-hero__search {
    max-width: var(--container-page);
    margin-top: var(--space-10);
  }

  .recent-change-list {
    border-top: var(--rule-strong);
  }

  .recent-change-row {
    display: grid;
    grid-template-columns: 7rem 9rem minmax(0, 1fr) auto;
    gap: var(--space-5);
    align-items: center;
    padding-block: var(--space-5);
    border-bottom: var(--rule-standard);
  }

  .recent-change-row time,
  .recent-change-row__type {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }

  .recent-change-row__type {
    color: var(--color-accent);
  }

  .recent-change-row h3 {
    margin: 0 0 var(--space-1);
    font-size: var(--font-size-h3);
  }

  .recent-change-row h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  .recent-change-row p {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: var(--rule-strong);
    border-bottom: var(--rule-strong);
  }

  .explore-item {
    padding: var(--space-8) var(--space-6);
    border-right: var(--rule-standard);
    color: var(--color-text);
    text-decoration: none;
  }

  .explore-item:last-child {
    border-right: 0;
  }

  .explore-item strong {
    display: block;
    margin-bottom: var(--space-3);
    font-size: var(--font-size-h3);
    font-weight: 500;
  }

  .explore-item span {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }

  .home-info-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-12);
  }

  .home-info-grid article {
    padding-left: var(--space-5);
    border-left: var(--rule-accent);
  }

  .home-info-grid h3 {
    margin: 0 0 var(--space-3);
    font-size: var(--font-size-h3);
  }

  .home-info-grid p,
  .data-access p {
    color: var(--color-text-soft);
  }

  .data-access {
    max-width: var(--container-prose);
  }

  @media (max-width: 900px) {
    .recent-change-row {
      grid-template-columns: 6rem 8rem minmax(0, 1fr);
    }

    .recent-change-row :global(.yk-action-link) {
      grid-column: 3;
    }

    .explore-grid {
      grid-template-columns: 1fr;
    }

    .explore-item {
      border-right: 0;
      border-bottom: var(--rule-standard);
    }

    .explore-item:last-child {
      border-bottom: 0;
    }
  }

  @media (max-width: 640px) {
    .home-hero {
      padding-block: var(--space-14) var(--space-12);
    }

    .recent-change-row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .recent-change-row :global(.yk-action-link) {
      grid-column: auto;
      margin-top: var(--space-2);
    }

    .home-info-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }
</style>
