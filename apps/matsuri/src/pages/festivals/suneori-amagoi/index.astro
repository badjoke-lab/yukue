---
import ActionLink from "@badjoke-lab/yukue-ui/components/ActionLink.astro";
import ChangeTimeline from "@badjoke-lab/yukue-ui/components/ChangeTimeline.astro";
import Container from "@badjoke-lab/yukue-ui/components/Container.astro";
import DesignationList from "@badjoke-lab/yukue-ui/components/DesignationList.astro";
import EvidenceList from "@badjoke-lab/yukue-ui/components/EvidenceList.astro";
import OccurrenceTable from "@badjoke-lab/yukue-ui/components/OccurrenceTable.astro";
import OverviewGrid from "@badjoke-lab/yukue-ui/components/OverviewGrid.astro";
import PageShell from "@badjoke-lab/yukue-ui/components/PageShell.astro";
import PlaceMap from "@badjoke-lab/yukue-ui/components/PlaceMap.astro";
import RelationList from "@badjoke-lab/yukue-ui/components/RelationList.astro";
import Section from "@badjoke-lab/yukue-ui/components/Section.astro";
import SiteFooter from "@badjoke-lab/yukue-ui/components/SiteFooter.astro";
import SiteHeader from "@badjoke-lab/yukue-ui/components/SiteHeader.astro";
import { findMatsuriEntityDetail } from "../../../data/matsuri-projection.js";
import { buildFestivalDetailViewModel } from "../../../data/projection-view-models.js";

const navItems = [
  { label: "祭礼", href: "/festivals/", active: true },
  { label: "民俗芸能", href: "/performances/" },
  { label: "地域", href: "/regions/" },
  { label: "変化", href: "/changes/" },
  { label: "検索", href: "/search/" },
  { label: "このサイトについて", href: "/about/" },
];

const footerGroups = [
  {
    heading: "記録",
    links: [
      { label: "祭礼", href: "/festivals/" },
      { label: "民俗芸能", href: "/performances/" },
      { label: "組織", href: "/organizations/" },
    ],
  },
  {
    heading: "調べる",
    links: [
      { label: "地域", href: "/regions/" },
      { label: "変化", href: "/changes/" },
      { label: "状態", href: "/states/" },
    ],
  },
  {
    heading: "この資料について",
    links: [
      { label: "方法論", href: "/methodology/" },
      { label: "データ", href: "/data/" },
      { label: "ステータス", href: "/status/" },
    ],
  },
];

const detail = findMatsuriEntityDetail("fst-suneori-amagoi");
if (!detail) {
  throw new Error("Public Projection is missing fst-suneori-amagoi.");
}
const page = buildFestivalDetailViewModel(detail);
---

<PageShell
  site="matsuri"
  title={page.title}
  description={page.description}
>
  <SiteHeader
    slot="header"
    siteName="祭のゆくえ"
    romanLabel="Matsuri Yukue"
    navItems={navItems}
  />

  <nav class="breadcrumb" aria-label="パンくずリスト">
    <Container size="wide">
      <ol>
        <li><a href="/">ホーム</a></li>
        <li><a href="/festivals/">祭礼</a></li>
        <li><a href="/regions/saitama/">{page.region}</a></li>
        <li aria-current="page">{page.name}</li>
      </ol>
    </Container>
  </nav>

  <section class="entity-identity">
    <Container size="wide">
      <p class="entity-identity__kicker">祭礼記録</p>
      <h1>{page.name}</h1>
      {page.reading && <p class="entity-identity__reading">{page.reading}</p>}
      {page.meta.length > 0 && (
        <ul class="entity-identity__meta" aria-label="基本分類">
          {page.meta.map((item) => <li>{item}</li>)}
        </ul>
      )}
    </Container>
  </section>

  <Section kicker="Overview" title="概要" actionHref="#evidence" actionLabel="観測根拠を見る">
    <OverviewGrid items={page.overview} />
  </Section>

  <Section kicker="About" title={`${page.name}について`}>
    <div class="yk-prose detail-prose">
      {page.aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </Section>

  <Section kicker="Places & Map" title="場所" id="places">
    {page.places.length > 0 ? (
      <PlaceMap
        places={page.places}
        contextDescription={page.placeContext}
      />
    ) : (
      <p class="empty-state">公開中の場所記録はまだありません。</p>
    )}
  </Section>

  <Section kicker="Year by Year" title="開催履歴">
    {page.occurrences.length > 0 ? (
      <OccurrenceTable
        rows={page.occurrences}
        showScale={true}
        caption={`${page.name}の開催履歴`}
      />
    ) : (
      <p class="empty-state">公開中の開催履歴はまだありません。</p>
    )}
  </Section>

  <Section kicker="Change History" title="変化の履歴">
    {page.changes.length > 0 ? (
      <ChangeTimeline items={page.changes} />
    ) : (
      <p class="empty-state">公開中の変化記録はまだありません。</p>
    )}
  </Section>

  <Section kicker="Connections" title="関係する場所・組織">
    {page.relations.length > 0 ? (
      <RelationList items={page.relations} />
    ) : (
      <p class="empty-state">公開中の関係記録はまだありません。</p>
    )}
  </Section>

  <Section kicker="Designations" title="指定">
    {page.designations.length > 0 ? (
      <DesignationList items={page.designations} />
    ) : (
      <p class="empty-state">公開中の指定記録はまだありません。</p>
    )}
  </Section>

  <Section kicker="Evidence & Sources" title="根拠と出典" id="evidence">
    {page.evidence.length > 0 ? (
      <EvidenceList items={page.evidence} />
    ) : (
      <p class="empty-state">公開中の根拠記録はまだありません。</p>
    )}
  </Section>

  <Section kicker="Machine-readable Data" title="機械可読データ" rule="none">
    <div class="machine-data">
      <p>このページは、承認済みcanonical dataを検証し、Public Projectionを通して生成しています。機械可読な公開ファイルは後続工程で同じProjectionから生成します。</p>
      <ActionLink href="/data/" label="公開データについて" />
    </div>
  </Section>

  <SiteFooter
    slot="footer"
    siteName="祭のゆくえ"
    groups={footerGroups}
  />
</PageShell>

<style>
  .breadcrumb {
    padding-block: var(--space-4);
    border-bottom: var(--rule-standard);
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
    list-style: none;
    color: var(--color-muted);
    font-size: var(--font-size-xs);
  }

  .breadcrumb li:not(:last-child)::after {
    content: "／";
    margin-left: var(--space-2);
    color: var(--color-rule-strong);
  }

  .breadcrumb a {
    color: inherit;
  }

  .entity-identity {
    padding-block: var(--space-14) var(--space-10);
    border-bottom: var(--rule-standard);
  }

  .entity-identity__kicker {
    margin: 0 0 var(--space-3);
    color: var(--color-accent);
    font-size: var(--font-size-sm);
    letter-spacing: 0.12em;
  }

  .entity-identity h1 {
    margin: 0;
    font-size: var(--font-size-entity);
    font-weight: 500;
    letter-spacing: 0.08em;
  }

  .entity-identity__reading {
    margin: var(--space-2) 0 0;
    color: var(--color-muted);
    font-size: var(--font-size-sm);
    letter-spacing: 0.08em;
  }

  .entity-identity__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin: var(--space-6) 0 0;
    padding: 0;
    list-style: none;
    color: var(--color-text-soft);
    font-size: var(--font-size-sm);
  }

  .entity-identity__meta li + li {
    padding-left: var(--space-4);
    border-left: var(--rule-standard);
  }

  .detail-prose {
    font-size: var(--font-size-base);
  }

  .machine-data {
    max-width: var(--container-prose);
  }

  .machine-data p,
  .empty-state {
    color: var(--color-text-soft);
  }

  @media (max-width: 640px) {
    .entity-identity {
      padding-block: var(--space-10) var(--space-8);
    }

    .entity-identity__meta {
      display: grid;
      gap: var(--space-2);
    }

    .entity-identity__meta li + li {
      padding-left: 0;
      border-left: 0;
    }
  }
</style>
